ENVIRONMENT=DEV
KC_URL=http://auth.pionera.oeg.fi.upm.es
KC_INTERNAL_URL=http://auth.pionera.oeg.fi.upm.es
KEYCLOAK_HOSTNAME=auth.pionera.oeg.fi.upm.es
KEYCLOAK_ADMIN_HOSTNAME=admin.auth.pionera.oeg.fi.upm.es
KC_USER=admin
KC_PASSWORD=change-me
PG_HOST=localhost
DATABASE_HOSTNAME=common-srvs-postgresql.common-srvs.svc
PG_USER=postgres
PG_PASSWORD=change-me
MINIO_HOSTNAME=minio.pionera.oeg.fi.upm.es
MINIO_CONSOLE_HOSTNAME=console.minio-s3.pionera.oeg.fi.upm.es
MINIO_USER=admin
MINIO_PASSWORD=change-me
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ADMIN_USER=admin
MINIO_ADMIN_PASS=change-me
VAULT_URL=http://common-srvs-vault.common-srvs.svc:8200
VT_URL=http://127.0.0.1:8200
VT_TOKEN=
DOMAIN_BASE=pionera.oeg.fi.upm.es
DS_DOMAIN_BASE=pionera.oeg.fi.upm.es
CLUSTER_TYPE=minikube
MINIKUBE_PROFILE=minikube
K3S_KUBECONFIG=/etc/rancher/k3s/k3s.yaml
VM_EXTERNAL_IP=
VM_COMMON_IP=192.168.122.64            # IP of the VM host (e.g. 192.168.122.64). Used by setup-nginx-proxy.sh (auto-run at Level 4 when PUBLIC_HOSTNAME is set)
VM_DATASPACE_IP=
VM_CONNECTORS_IP=
VM_COMPONENTS_IP=
INGRESS_EXTERNAL_IP=
TOPOLOGY_ROUTING_MODE=host
PUBLIC_HOSTNAME=org1.pionera.oeg.fi.upm.es         # Public hostname for external browser access (e.g. org1.pionera.oeg.fi.upm.es). Triggers nginx proxy setup at Level 4.
