ENVIRONMENT=DEV
PG_HOST=localhost
PG_USER=postgres
PG_PASSWORD=CHANGE_ME
KC_URL=http://keycloak-admin.dev.ed.dataspaceunit.upm
KC_USER=admin
KC_PASSWORD=CHANGE_ME
KC_INTERNAL_URL=http://keycloak.dev.ed.dataspaceunit.upm
VT_URL=http://localhost:8200
VT_TOKEN=X
DATABASE_HOSTNAME=common-srvs-postgresql.common-srvs.svc
KEYCLOAK_HOSTNAME=keycloak.dev.ed.dataspaceunit.upm
MINIO_HOSTNAME=minio.dev.ed.dataspaceunit.upm
VAULT_URL=http://common-srvs-vault.common-srvs.svc:8200
DOMAIN_BASE=dev.ed.dataspaceunit.upm
DS_DOMAIN_BASE=dev.ds.dataspaceunit.upm
MINIO_USER=admin
MINIO_PASSWORD=CHANGE_ME
DS_1_NAME=demo
DS_1_NAMESPACE=demo
DS_1_CONNECTORS=citycouncil,company
COMPONENTS=ontology-hub

# Optional Kafka settings used by the benchmark helper and Level 6.
# These values are also used as the shared Kafka source of truth by the adapter.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Optional: bootstrap address reachable from connector pods. If omitted, the
# EDC+Kafka suite derives one from KAFKA_BOOTSTRAP_SERVERS for local runtimes.
# KAFKA_CLUSTER_BOOTSTRAP_SERVERS=host.docker.internal:9092
# Optional: hostname that the framework-managed Kafka testcontainer should
# advertise to connector pods when it auto-provisions a broker.
# KAFKA_CLUSTER_ADVERTISED_HOST=host.docker.internal
KAFKA_TOPIC_NAME=kafka-stream-topic
KAFKA_TOPIC_STRATEGY=STATIC_TOPIC
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_CONTAINER_NAME=kafka-local
KAFKA_CONTAINER_IMAGE=confluentinc/cp-kafka:7.5.2
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_USERNAME=framework
# KAFKA_PASSWORD=framework-secret
# KAFKA_CONTAINER_ENV_FILE=tests/fixtures/kafka/sasl.env
# KAFKA_DATAPLANE_SINK_PARTITION_SIZE=5
# LEVEL6_RUN_KAFKA_EDC=true
# KAFKA_EDC_MESSAGE_COUNT=10
# KAFKA_EDC_NEGOTIATION_TIMEOUT_SECONDS=60
# KAFKA_EDC_TRANSFER_TIMEOUT_SECONDS=60
# KAFKA_EDC_EDR_TIMEOUT_SECONDS=30
# KAFKA_EDC_POLL_INTERVAL_SECONDS=3
# KAFKA_EDC_CONSUMER_POLL_TIMEOUT_SECONDS=30
# KAFKA_EDC_STARTUP_GRACE_SECONDS=60
# KAFKA_EDC_PRE_RUN_SETTLE_SECONDS=10
