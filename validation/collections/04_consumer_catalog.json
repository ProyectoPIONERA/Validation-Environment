{
  "info": {
    "name": "04 Consumer Catalog Discovery",
    "_postman_id": "consumer-catalog-04",
    "description": "Consumer retrieves provider catalog through Management API and DSP protocol",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "eval(pm.environment.get('test_script'));"
        ]
      }
    }
  ],

  "item": [

    {
      "name": "Request Federated Catalog (Management API)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{consumer}}.{{dsDomain}}/management/v3/catalog/request",
          "host": [
            "{{consumer}}",
            "{{dsDomain}}"
          ],
          "path": [
            "management",
            "v3",
            "catalog",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"@type\": \"CatalogRequest\",\n  \"counterPartyAddress\": \"{{providerProtocolAddress}}\",\n  \"counterPartyId\": \"{{provider}}\",\n  \"protocol\": \"dataspace-protocol-http\",\n  \"querySpec\": {\n    \"offset\": 0,\n    \"limit\": 10,\n    \"filterExpression\": []\n  }\n}"
        }
      }
    },

    {
      "name": "Direct DSP Catalog Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://{{provider}}.{{dsDomain}}/protocol/catalog/request",
          "host": [
            "{{provider}}",
            "{{dsDomain}}"
          ],
          "path": [
            "protocol",
            "catalog",
            "request"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"@context\": {\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\n  },\n  \"@type\": \"CatalogRequest\",\n  \"counterPartyAddress\": \"{{providerProtocolAddress}}\",\n  \"counterPartyId\": \"{{provider}}\",\n  \"protocol\": \"dataspace-protocol-http\",\n  \"querySpec\": {\n    \"offset\": 0,\n    \"limit\": 10,\n    \"filterExpression\": []\n  }\n}"
        }
      }
    }

  ]
}